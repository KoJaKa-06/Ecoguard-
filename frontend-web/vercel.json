{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://ecoguard-production-3417.up.railway.app/api/$1" },
    { "source": "/uploads/(.*)", "destination": "https://ecoguard-production-3417.up.railway.app/uploads/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
